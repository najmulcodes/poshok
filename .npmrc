
# next@15.0.0-rc.0 (used in apps/web) is a prerelease version string that
# doesn't satisfy next-intl's peer range (which only lists stable major
# versions), even though next-intl works fine with it in practice. Without
# this, a plain `npm install` from a fresh clone fails outright with
# ERESOLVE. Safe to remove once apps/web is upgraded to a stable Next.js 15
# release.
legacy-peer-deps=true
