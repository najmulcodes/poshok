# Make a copy of this file called .env and fill in the values.
# Do NOT commit .env to source control.

# Redis connection string for BullMQ.
# Local dev:  redis://localhost:6379
# Upstash:    rediss://default:YOUR_PASSWORD@YOUR-ENDPOINT.upstash.io:6379
#             (note the "rediss" with a double s — this is TLS, and Upstash
#             requires it. Find this under your database's "Connect" tab,
#             the "ioredis" or "Node" connection string.)
REDIS_URL="redis://localhost:6379"

# The connection string for your PostgreSQL database.
# Supabase: use the *pooled* (transaction mode / port 6543) connection
# string here, found under Project Settings -> Database -> Connection
# string -> "Transaction" mode. It looks like:
# postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Direct (non-pooled) connection URL — required for Prisma migrations.
# Supabase: same page as above, but the "Session" mode string on port 5432
# (no ?pgbouncer=true):
# postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT Secrets - Use strong, long, random strings in production
# You can generate these with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-key"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"

# Token expiration (e.g., 15m, 1h, 7d)
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

# Server port
PORT=3001

# A secret to protect the internal cron endpoint
INTERNAL_CRON_SECRET="your-super-secret-cron-key"

# Set to "true" to run the notification worker + dispatch scheduler inside
# this same process, instead of as a separate service. Use this if you're
# on a free-tier host that doesn't support a second background-worker
# service (e.g. Render's free plan). Leave unset/false if you're running
# `npm run worker` as its own separate process/service.
RUN_WORKER_INPROCESS="true"

# Comma-separated list of allowed origins for CORS in production.
# e.g. CORS_ORIGIN="https://nevocore.vercel.app,https://your-custom-domain.com"
CORS_ORIGIN=""

# Optional: override the admin account created by `npm run db:seed`.
# If ADMIN_SEED_PASSWORD is left unset, a random password is generated and
# printed once to the console when seeding.
ADMIN_SEED_EMAIL="admin@nevocore.app"
ADMIN_SEED_PASSWORD=""