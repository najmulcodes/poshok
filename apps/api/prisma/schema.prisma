generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  expoPushToken String?  @unique
  role          Role     @default(USER)
  createdAt     DateTime @default(now())
  healthProfile HealthProfile?
  favorites     FavoriteDietPlan[]
  mealCompletions MealCompletion[]
  subscriptions PlanSubscription[]
  notifications Notification[]
}

enum Role {
  USER
  ADMIN
}

model HealthProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  condition   Condition
  ageGroup    AgeGroup?
  language    Language  @default(BN)
  breakfastTime String? // Store as "HH:mm:ss"
  lunchTime     String?
  dinnerTime    String?
  snackTime     String?
  updatedAt   DateTime  @updatedAt
}

enum Condition {
  DIABETES
  CARDIAC
  GENERAL
  CHILD
}

enum AgeGroup {
  TWO_TO_FIVE
  SIX_TO_TEN
}

enum Language {
  EN
  BN
}

model DietPlan {
  id            String   @id @default(cuid())
  condition     Condition
  ageGroup      AgeGroup?
  titleEn       String
  titleBn       String
  version       Int      @default(1)
  isPublished   Boolean  @default(false)
  createdById   String
  createdAt     DateTime @default(now())
  meals         Meal[]
  subscriptions PlanSubscription[]
  favoritedBy   FavoriteDietPlan[]

  @@index([condition, ageGroup, isPublished])
}

model Meal {
  id          String   @id @default(cuid())
  dietPlanId  String
  dietPlan    DietPlan @relation(fields: [dietPlanId], references: [id])
  mealType    MealType
  descriptionEn String
  descriptionBn String
  calories    Int?
  order       Int
  completions MealCompletion[]
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model PlanSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietPlanId  String
  dietPlan    DietPlan @relation(fields: [dietPlanId], references: [id])
  subscribedAt DateTime @default(now())

  @@unique([userId, dietPlanId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  channel     NotificationChannel
  status      NotificationStatus @default(PENDING)
  mealType    MealType?
  scheduledAt DateTime
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([status, scheduledAt])
}

enum NotificationType {
  MEAL_REMINDER
  PLAN_UPDATED
}

enum NotificationChannel {
  PUSH
  IN_APP
  EMAIL
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model MealCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealId      String
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  completedOn DateTime @db.Date
  createdAt   DateTime @default(now())

  @@unique([userId, mealId, completedOn])
  @@index([userId, completedOn])
}

model FavoriteDietPlan {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dietPlanId String
  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, dietPlanId])
  @@index([userId])
}